{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unfold",
  "identifier": "com.mathangik.unfold",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "app": {
    "enableGTKAppId": false,
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/**"
        ]
      },
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": false,
      "pattern": {
        "use": "brownfield"
      }
    },
    "windows": [
      {
        "maximizable": true,
        "minHeight": 800,
        "minWidth": 200,
        "minimizable": true,
        "decorations": true,
        "label": "main",
        "maximized": true,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "title": "Unfold",
        "shadow": false,
        "backgroundColor": "#0D0D0C",
        "visible": false
      }
    ],
    "withGlobalTauri": false
  }
}