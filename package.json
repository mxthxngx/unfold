{
  "name": "unfold",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc && vite build",
    "check": "pnpm typecheck && pnpm build",
    "lint": "eslint src",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "pnpm exec prettier --write",
      "pnpm lint",
      "sh -c 'pnpm typecheck'"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint"
      ]
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@radix-ui/react-context-menu": "^2.2.16",
