    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "@tiptap/y-tiptap": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "husky": "^9.1.7",
    "jspdf": "^4.2.0",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "motion": "^12.35.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "tailwind-merge": "^3.5.0",
